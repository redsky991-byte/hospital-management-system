# MedCare HMS - Environment Configuration
#
# NOTE: This file is for the legacy Node.js backend (server.js) only.
# The primary Java/Spring Boot backend is configured via:
#   java-backend/src/main/resources/application.properties
# and the JWT_SECRET environment variable.
#
# Copy this file to .env if you need to run the Node.js backend:
#   cp .env.example .env

# Server port (default: 3000)
PORT=3000

# JWT secret key - CHANGE THIS in production!
JWT_SECRET=your-strong-secret-key-here

# Node environment
NODE_ENV=development
